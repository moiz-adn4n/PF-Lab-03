// ===========================
// Problem 1: Circular Right Shift
// ===========================
int main() {
    int arr[5];
    int last;
    int i;

    printf("Enter 5 integers: ");
    for (i = 0; i < 5; i++) {
        scanf("%d", &arr[i]);
    }

    // save last element
    last = arr[4];

    // move each element one step to the right
    arr[4] = arr[3];
    arr[3] = arr[2];
    arr[2] = arr[1];
    arr[1] = arr[0];

    // put last element at the front
    arr[0] = last;

    printf("Shifted: ");
    for (i = 0; i < 5; i++) {
        printf("%d ", arr[i]);
    }
    printf("\n");

    return 0;
}

