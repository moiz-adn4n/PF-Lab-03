// ===========================
// Problem 3: Pass / Fail Separation
// ===========================
int main() {
    int pass[10];
    int fail[10];
    int pc;
    int fc;
    int mark;
    float psum;
    float fsum;
    float pavg;
    float favg;
    int i;

    pc   = 0;
    fc   = 0;
    psum = 0;
    fsum = 0;

    printf("Enter marks one by one. Enter -1 to stop:\n");

    while (1) {
        scanf("%d", &mark);

        if (mark == -1) {
            break;
        }

        if (mark >= 5 && mark <= 10) {
            pass[pc] = mark;
            pc = pc + 1;
            psum = psum + mark;
        }

        if (mark >= 0 && mark < 5) {
            fail[fc] = mark;
            fc = fc + 1;
            fsum = fsum + mark;
        }
    }

    printf("Pass marks: ");
    for (i = 0; i < pc; i++) {
        printf("%d ", pass[i]);
    }

    if (pc == 0) {
        pavg = 0;
    } else {
        pavg = psum / pc;
    }
    printf("\nPass average: %.2f\n", pavg);

    printf("Fail marks: ");
    for (i = 0; i < fc; i++) {
        printf("%d ", fail[i]);
    }

    if (fc == 0) {
        favg = 0;
    } else {
        favg = fsum / fc;
    }
    printf("\nFail average: %.2f\n", favg);

    return 0;
}
