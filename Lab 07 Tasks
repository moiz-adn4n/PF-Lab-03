// ===========================
// Problem 4: Toggle Case
// ===========================
int main() {
    char str[200];
    int i;

    printf("Enter a sentence: ");
    scanf(" %[^\n]", str);

    for (i = 0; str[i] != '\0'; i++) {

        // if lowercase, convert to uppercase
        if (str[i] >= 'a' && str[i] <= 'z') {
            str[i] = str[i] - 32;
        }

        // if uppercase, convert to lowercase
        else if (str[i] >= 'A' && str[i] <= 'Z') {
            str[i] = str[i] + 32;
        }

        // if space or symbol, leave it as it is
    }

    printf("Converted: %s\n", str);

    return 0;
}
