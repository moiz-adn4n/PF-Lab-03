// ===========================
// Problem 2: Count Occurrences
// ===========================
int main() {
    int arr[10];
    int target;
    int count;
    int i;

    printf("Enter 10 numbers: ");
    for (i = 0; i < 10; i++) {
        scanf("%d", &arr[i]);
    }

    printf("Enter number to search: ");
    scanf("%d", &target);

    count = 0;
    for (i = 0; i < 10; i++) {
        if (arr[i] == target) {
            count = count + 1;
        }
    }

    if (count == 0) {
        printf("Number not found\n");
    } else {
        printf("Number found %d time(s)\n", count);
    }

    return 0;
}
