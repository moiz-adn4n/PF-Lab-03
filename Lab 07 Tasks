// ===========================
// Problem 7: Mark Duplicates as -1
// ===========================
int main() {
    int arr[10];
    int i;
    int j;

    printf("Enter 10 integers: ");
    for (i = 0; i < 10; i++) {
        scanf("%d", &arr[i]);
    }

    for (i = 0; i < 10; i++) {

        // skip elements already marked as duplicate
        if (arr[i] == -1) {
            continue;
        }

        // compare with every element after it
        for (j = i + 1; j < 10; j++) {
            if (arr[j] == arr[i]) {
                arr[j] = -1;
            }
        }
    }

    printf("Result: ");
    for (i = 0; i < 10; i++) {
        printf("%d ", arr[i]);
    }
    printf("\n");

    return 0;
}
