// ===========================
// Problem 5: Max minus Min
// ===========================
int main() {
    int arr[10];
    int i;
    int max;
    int min;
    int difference;

    printf("Enter 10 integers: ");
    for (i = 0; i < 10; i++) {
        scanf("%d", &arr[i]);
    }

    // start by assuming first element is both max and min
    max = arr[0];
    min = arr[0];

    for (i = 1; i < 10; i++) {
        if (arr[i] > max) {
            max = arr[i];
        }
        if (arr[i] < min) {
            min = arr[i];
        }
    }

    difference = max - min;
    printf("Largest:    %d\n", max);
    printf("Smallest:   %d\n", min);
    printf("Difference: %d\n", difference);

    return 0;
}
