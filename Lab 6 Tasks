/* -------------------- Q10 -------------------- */
#include <stdio.h>

int main() {
    int score;
    int distinction = 0, pass = 0, fail = 0;

    printf("Enter student scores (0–100). Enter -1 to stop.\n");
    scanf("%d", &score);

    while (score != -1) {

        if (score >= 75 && score <= 100) {
            distinction++;
        }
        else if (score >= 50 && score <= 74) {
            pass++;
        }
        else if (score >= 0 && score < 50) {
            fail++;
        }
        else {
            printf("Invalid score! Please enter between 0 and 100.\n");
        }

        scanf("%d", &score);
    }

    printf("\n--- Result Summary ---\n");
    printf("Distinction: %d\n", distinction);
    printf("Pass: %d\n", pass);
    printf("Fail: %d\n", fail);

    return 0;
}

/* -------------------- Q11 -------------------- */
#include <stdio.h>

int main() {
    float price, total = 0, discount = 0, finalAmount;
    int choice;

    do {
        printf("Enter product price: ");
        scanf("%f", &price);

        total += price;

        printf("Add another product? (1 = Yes, 0 = No): ");
        scanf("%d", &choice);

    } while (choice == 1);

    if (total > 5000) {
        discount = total * 0.05;
    }

    finalAmount = total - discount;

    printf("\n--- Bill Summary ---\n");
    printf("Total Amount: %.2f\n", total);
    printf("Discount: %.2f\n", discount);
    printf("Final Payable Amount: %.2f\n", finalAmount);

    return 0;
}

/* -------------------- Q12 -------------------- */
#include <stdio.h>

int main() {
    int totalSeats = 40;
    int bookedSeats = 0;
    int choice;

    while (bookedSeats < totalSeats) {

        printf("\nEnter 1 to book a seat (0 to stop): ");
        scanf("%d", &choice);

        if (choice == 0) {
            printf("Reservations stopped by operator.\n");
            break;
        }
        else if (choice == 1) {
            bookedSeats++;
            printf("Seat booked successfully!\n");
            printf("Remaining seats: %d\n", totalSeats - bookedSeats);
        }
        else {
            printf("Invalid input. Please enter 1 or 0.\n");
        }
    }

    if (bookedSeats == totalSeats) {
        printf("\nAll seats are fully booked!\n");
    }

    printf("\nTotal seats booked: %d\n", bookedSeats);
    printf("Total seats remaining: %d\n", totalSeats - bookedSeats);

    return 0;
}
