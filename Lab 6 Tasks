/* -------------------- Q5 -------------------- */
#include <stdio.h>

int main() {
    float temperature;
    float sum = 0;
    int count = 0;

    printf("Enter temperature readings (-999 to stop): ");
    scanf("%f", &temperature);

    while (temperature != -999) {
        sum = sum + temperature;
        count++;

        printf("Enter temperature reading (-999 to stop): ");
        scanf("%f", &temperature);
    }

    if (count > 0) {
        float average = sum / count;
        printf("\nAverage Temperature = %.2f\n", average);
    } else {
        printf("\nNo valid temperature readings entered.\n");
    }

    return 0;
}

