/* -------------------- Q1 -------------------- */
#include <stdio.h>

int main() {
    int attendance;
    int totalPresent = 0;

    for(int i = 1; i <= 30; i++) {
        printf("Enter attendance for student %d (1 = Present, 0 = Absent): ", i);
        scanf("%d", &attendance);

        if(attendance == 1) {
            totalPresent++;
        }
    }

    printf("\nTotal number of students present: %d\n", totalPresent);
    return 0;
}

/* -------------------- Q2 -------------------- */
#include <stdio.h>

int main() {
    float balance, withdrawal;

    printf("Enter your initial balance: ");
    scanf("%f", &balance);

    while (balance > 0) {
        printf("\nCurrent Balance: %.2f", balance);
        printf("\nEnter withdrawal amount: ");
        scanf("%f", &withdrawal);

        balance = balance - withdrawal;

        if (balance > 0) {
            printf("Withdrawal successful.\n");
        } else {
            printf("Balance unsuccessful.\n");
        }
    }

    printf("\nTransaction ended. Final Balance: %.2f\n", balance);
    return 0;
}

