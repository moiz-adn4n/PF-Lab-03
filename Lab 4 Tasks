/* -------------------- Task 6 -------------------- */
#include <stdio.h>

int main() {
    float marks1, marks2, marks3, marks4, marks5;
    float totalMarks, percentage;

    printf("Scholarship Evaluation System\n");
    printf("==============================\n\n");

    printf("Enter marks for Subject 1 (0-100): ");
    scanf("%f", &marks1);

    printf("Enter marks for Subject 2 (0-100): ");
    scanf("%f", &marks2);

    printf("Enter marks for Subject 3 (0-100): ");
    scanf("%f", &marks3);

    printf("Enter marks for Subject 4 (0-100): ");
    scanf("%f", &marks4);

    printf("Enter marks for Subject 5 (0-100): ");
    scanf("%f", &marks5);

    // Validate input
    if (marks1 < 0 || marks1 > 100 ||
        marks2 < 0 || marks2 > 100 ||
        marks3 < 0 || marks3 > 100 ||
        marks4 < 0 || marks4 > 100 ||
        marks5 < 0 || marks5 > 100) {

        printf("Invalid input! Marks must be between 0 and 100.\n");
        return 1;
    }

    totalMarks = marks1 + marks2 + marks3 + marks4 + marks5;
    percentage = (totalMarks / 500) * 100;

    printf("\nTotal Marks: %.2f/500\n", totalMarks);
    printf("Percentage: %.2f%%\n\n", percentage);

    if (percentage >= 85) {
        printf("Result: Full Scholarship\n");
    } 
    else if (percentage >= 70) {
        printf("Result: Partial Scholarship\n");
    } 
    else if (percentage >= 50) {
        printf("Result: Eligible for Consideration\n");
    } 
    else {
        printf("Result: Not Eligible\n");
    }

    return 0;
}


/* -------------------- Task 7 -------------------- */
#include <stdio.h>

int main() {
    float purchaseAmount, discount, finalAmount;

    printf("Festival Sale Discount Calculator\n");
    printf("==================================\n\n");

    printf("Enter total purchase amount: ");
    scanf("%f", &purchaseAmount);

    if (purchaseAmount < 0) {
        printf("Invalid input! Purchase amount cannot be negative.\n");
        return 1;
    }

    if (purchaseAmount >= 5000) {
        discount = purchaseAmount * 0.20;
        printf("Discount: 20%%\n");
    } 
    else if (purchaseAmount >= 3000) {
        discount = purchaseAmount * 0.10;
        printf("Discount: 10%%\n");
    } 
    else {
        discount = 0;
        printf("Discount: No discount\n");
    }

    finalAmount = purchaseAmount - discount;

    printf("Original Amount: %.2f\n", purchaseAmount);
    printf("Discount Amount: %.2f\n", discount);
    printf("Final Amount: %.2f\n", finalAmount);

    return 0;
}


/* -------------------- Task 8 -------------------- */
#include <stdio.h>
#include <math.h>

int main() {
    int choice;
    double num1, num2, result;

    printf("Math Operations Console\n");
    printf("=======================\n\n");

    printf("1. Addition\n");
    printf("2. Subtraction\n");
    printf("3. Multiplication\n");
    printf("4. Division\n");
    printf("5. Square of a number\n");
    printf("6. Cube of a number\n");
    printf("7. Square Root of a number\n");
    printf("8. Power (x^y)\n");
    printf("9. Absolute Value\n");
    printf("10. Modulus\n\n");

    printf("Enter your choice (1-10): ");
    scanf("%d", &choice);

    switch (choice) {

        case 1:
            printf("Enter two numbers: ");
            scanf("%lf %lf", &num1, &num2);
            result = num1 + num2;
            printf("Result: %.2lf\n", result);
            break;

        case 2:
            printf("Enter two numbers: ");
            scanf("%lf %lf", &num1, &num2);
            result = num1 - num2;
            printf("Result: %.2lf\n", result);
            break;

        case 3:
            printf("Enter two numbers: ");
            scanf("%lf %lf", &num1, &num2);
            result = num1 * num2;
            printf("Result: %.2lf\n", result);
            break;

        case 4:
            printf("Enter two numbers: ");
            scanf("%lf %lf", &num1, &num2);

            if (num2 == 0)
                printf("Error: Division by zero is not allowed!\n");
            else {
                result = num1 / num2;
                printf("Result: %.2lf\n", result);
            }
            break;

        case 5:
            printf("Enter a number: ");
            scanf("%lf", &num1);
            result = num1 * num1;
            printf("Result: %.2lf\n", result);
            break;

        case 6:
            printf("Enter a number: ");
            scanf("%lf", &num1);
            result = num1 * num1 * num1;
            printf("Result: %.2lf\n", result);
            break;

        case 7:
            printf("Enter a number: ");
            scanf("%lf", &num1);

            if (num1 < 0)
                printf("Error: Square root of negative number is not allowed!\n");
            else {
                result = sqrt(num1);
                printf("Result: %.2lf\n", result);
            }
            break;

        case 8:
            printf("Enter base and exponent: ");
            scanf("%lf %lf", &num1, &num2);
            result = pow(num1, num2);
            printf("Result: %.2lf\n", result);
            break;

        case 9:
            printf("Enter a number: ");
            scanf("%lf", &num1);
            result = fabs(num1);
            printf("Result: %.2lf\n", result);
            break;

        case 10: {
            int int1, int2;

            printf("Enter two integers: ");
            scanf("%d %d", &int1, &int2);

            if (int2 == 0)
                printf("Error: Modulus by zero is not allowed!\n");
            else
                printf("Result: %d %% %d = %d\n", int1, int2, int1 % int2);
            break;
        }

        default:
            printf("Invalid choice! Please select a valid option (1-10).\n");
    }

    return 0;
}
