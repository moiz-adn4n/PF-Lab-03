#include <stdio.h>

int main() {
    int category, subType, quantity;
    float price, bill;

    printf("Select Book Category:\n");
    printf("1. Fiction\n");
    printf("2. Non-Fiction\n");
    printf("Enter choice: ");
    scanf("%d", &category);

    switch (category) {

        case 1:
            printf("\nSelect Fiction Type:\n");
            printf("1. Novel (Rs. 600)\n");
            printf("2. Comic (Rs. 300)\n");
            printf("Enter choice: ");
            scanf("%d", &subType);

            switch (subType) {
                case 1:
                    price = 600;
                    printf("Book : Novel\n");
                    break;
                case 2:
                    price = 300;
                    printf("Book : Comic\n");
                    break;
                default:
                    printf("Invalid choice!\n");
                    return 1;
            }
            break;

        case 2:
            printf("\nSelect Non-Fiction Type:\n");
            printf("1. Biography (Rs. 800)\n");
            printf("2. Self-Help (Rs. 500)\n");
            printf("Enter choice: ");
            scanf("%d", &subType);

            switch (subType) {
                case 1:
                    price = 800;
                    printf("Book : Biography\n");
                    break;
                case 2:
                    price = 500;
                    printf("Book : Self-Help\n");
                    break;
                default:
                    printf("Invalid choice!\n");
                    return 1;
            }
            break;

        default:
            printf("Invalid category!\n");
            return 1;
    }

    printf("Enter Quantity: ");
    scanf("%d", &quantity);

    bill = price * quantity;

    printf("Price : Rs. %.2f\n", price);
    printf("Quantity : %d\n", quantity);
    printf("Total : Rs. %.2f\n", bill);

    return 0;
}


