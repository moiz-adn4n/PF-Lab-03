#include <stdio.h>

int main() {
    float a, b, c, d;

    printf("Enter four side lengths:\n");
    printf("Side 1: "); scanf("%f", &a);
    printf("Side 2: "); scanf("%f", &b);
    printf("Side 3: "); scanf("%f", &c);
    printf("Side 4: "); scanf("%f", &d);

    if (a <= 0 || b <= 0 || c <= 0 || d <= 0) {
        printf("Not a valid quadrilateral!\n");
    } 
    else {
        if (a == b && b == c && c == d) {
            printf("Square\n");
        } 
        else if (a == c && b == d) {
            printf("Rectangle\n");
        } 
        else {
            printf("General Quadrilateral\n");
        }
    }

    return 0;
}


/* -------------------- Q7 -------------------- */
#include <stdio.h>

int main() {
    long cardNumber = 1234567890, enteredCard;
    int pin = 7890, enteredPin;
    float balance = 10000.0, amount;

    printf("Enter Card Number: ");
    scanf("%ld", &enteredCard);

    if (enteredCard == cardNumber) {

        printf("Enter PIN: ");
        scanf("%d", &enteredPin);

        if (enteredPin == pin) {

            printf("Enter Transaction Amount: Rs. ");
            scanf("%f", &amount);

            if (amount <= balance) {
                balance -= amount;

                printf("\nTransaction Successful!\n");
                printf("Amount Debited : Rs. %.2f\n", amount);
                printf("Remaining Balance: Rs. %.2f\n", balance);
            } 
            else {
                printf("\nInsufficient Funds!\n");
                printf("Available Balance: Rs. %.2f\n", balance);
            }
        } 
        else {
            printf("\nInvalid PIN!\n");
        }
    } 
    else {
        printf("\nInvalid Card!\n");
    }

    return 0;
}


/* -------------------- Q8 -------------------- */
#include <stdio.h>
#include <math.h>

int main() {
    int choice, gender;
    float weight, height, age, result;

    printf("1. BMI Calculation\n");
    printf("2. BMR Calculation\n");
    printf("3. Ideal Weight (Devine Formula)\n");
    printf("4. Heart Rate Zone\n");
    printf("Enter choice: ");
    scanf("%d", &choice);

    switch (choice) {

        case 1:
            printf("\nEnter Weight (kg): ");
            scanf("%f", &weight);
            printf("Enter Height (m): ");
            scanf("%f", &height);

            if (weight <= 0 || height <= 0) {
                printf("Error: Weight and Height must be positive!\n");
            } 
            else {
                result = weight / pow(height, 2);

                printf("\nBMI = %.2f\n", result);

                if (result < 18.5)
                    printf("Category: Underweight\n");
                else if (result < 24.9)
                    printf("Category: Normal Weight\n");
                else if (result < 29.9)
                    printf("Category: Overweight\n");
                else
                    printf("Category: Obese\n");
            }
            break;

        case 2:
            printf("\nEnter Weight (kg): ");
            scanf("%f", &weight);
            printf("Enter Height (cm): ");
            scanf("%f", &height);
            printf("Enter Age (years): ");
            scanf("%f", &age);
            printf("Gender (1=Male, 2=Female): ");
            scanf("%d", &gender);

            if (gender == 1)
                result = (10 * weight) + (6.25 * height) - (5 * age) + 5;
            else
                result = (10 * weight) + (6.25 * height) - (5 * age) - 161;

            printf("\nBMR = %.2f calories/day\n", result);
            break;

        case 3: {
            printf("\nEnter Height (cm): ");
            scanf("%f", &height);
            printf("Gender (1=Male, 2=Female): ");
            scanf("%d", &gender);

            float heightInches = height / 2.54;
            float extraInches = fabs(heightInches - 60);

            if (gender == 1)
                result = 50.0 + (2.3 * extraInches);
            else
                result = 45.5 + (2.3 * extraInches);

            printf("\nIdeal Weight = %.2f kg\n", result);
            break;
        }

        case 4:
            printf("\nEnter Age (years): ");
            scanf("%f", &age);

            if (age > 0) {
                float maxHR = 220 - age;

                printf("\nMax Heart Rate : %.0f bpm\n", maxHR);
                printf("-----------------------------\n");
                printf("Zone 1 (50%%): %.0f bpm\n", maxHR * 0.50);
                printf("Zone 2 (60%%): %.0f bpm\n", maxHR * 0.60);
                printf("Zone 3 (70%%): %.0f bpm\n", maxHR * 0.70);
                printf("Zone 4 (80%%): %.0f bpm\n", maxHR * 0.80);
                printf("Zone 5 (90%%): %.0f bpm\n", maxHR * 0.90);
            }
            else {
                printf("Error: Age must be positive!\n");
            }
            break;

        default:
            printf("Invalid choice!\n");
    }

    return 0;
}
