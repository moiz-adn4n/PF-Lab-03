#include <stdio.h>

int main() {
    float salary, incentiveRate, incentiveAmount;
    int years;

    printf("Enter Salary: ");
    scanf("%f", &salary);

    printf("Enter Years of Service: ");
    scanf("%d", &years);

    if (years > 15) {
