/* -------------------- Q1 -------------------- */
#include <stdio.h>

int main() {
    int age;
    float fitnessScore;

    printf("=== Fitness Center Membership Discount System ===\n\n");

    printf("Enter your Fitness Score (0-100): ");
    scanf("%f", &fitnessScore);

    printf("Enter your Age: ");
    scanf("%d", &age);

    printf("\n--- Result ---\n");

    if (fitnessScore >= 85) {
        if (age < 25) {
            printf("Congratulations! You qualify for a 40%% Discount.\n");
            printf("Reason: High fitness score (%.1f) and age under 25.\n", fitnessScore);
        } else {
            printf("Congratulations! You qualify for a 25%% Discount.\n");
            printf("Reason: High fitness score (%.1f) and age 25 or above.\n", fitnessScore);
        }
    } 
    else {
        if (fitnessScore >= 70 && age < 30) {
            printf("You qualify for a 15%% Discount.\n");
            printf("Reason: Moderate fitness score (%.1f) and age under 30.\n", fitnessScore);
        } 
        else {
            printf("Sorry, you do not qualify for any discount at this time.\n");
            printf("Reason: Fitness score (%.1f) is below 70 or age is 30+.\n", fitnessScore);
        }
    }

    return 0;
}


