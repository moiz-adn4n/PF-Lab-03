        bill = data * 25;
    }

    printf("Total Bill: Rs. %.2f\n", bill);

    return 0;
}


/* -------------------- Q3 -------------------- */
#include <stdio.h>

int main() {
    int mainType, subType;
    float weight, bill;

    printf("Enter Luggage Weight (kg): ");
    scanf("%f", &weight);

    printf("\nSelect Luggage Type:\n");
    printf("1. Handbag\n");
    printf("2. Checked Bag\n");
    printf("3. Sports Equipment\n");
    printf("Enter choice: ");
    scanf("%d", &mainType);

    switch (mainType) {

        case 1:
            printf("\nSelect Handbag Size:\n");
            printf("1. Small (Rs. 100/kg)\n");
            printf("2. Large (Rs. 200/kg)\n");
            printf("Enter choice: ");
            scanf("%d", &subType);

            switch (subType) {
                case 1: bill = weight * 100; break;
                case 2: bill = weight * 200; break;
                default:
                    printf("Invalid size choice!\n");
                    return 1;
            }
            break;

        case 2:
            printf("\nSelect Journey Type:\n");
            printf("1. Domestic (Rs. 300/kg)\n");
            printf("2. International (Rs. 500/kg)\n");
            printf("Enter choice: ");
            scanf("%d", &subType);

            switch (subType) {
                case 1: bill = weight * 300; break;
                case 2: bill = weight * 500; break;
                default:
                    printf("Invalid journey type!\n");
                    return 1;
            }
            break;

        case 3:
            bill = weight * 1000;
            break;

        default:
            printf("Invalid luggage type!\n");
            return 1;
    }

    printf("\nTotal Luggage Fee: Rs. %.2f\n", bill);

    return 0;
}


